{
  "enableInstallTelemetry": false,
  "compaction": {
    "enabled": true
  },
  "retry": {
    "enabled": true,
    "maxRetries": 2
  },
  "lastChangelogVersion": "0.70.5",
  "images": {
    "autoResize": true,
    "blockImages": true
  },
  "collapseChangelog": true,
  "doubleEscapeAction": "tree",
  "treeFilterMode": "default",
  "theme": "dark",
  "packages": [
    "npm:pi-mcp-adapter"
  ],
  "defaultProvider": "llamacpp",
  "defaultModel": "local",
  "defaultThinkingLevel": "low",
  "terminal": {
    "showTerminalProgress": false
  }
}